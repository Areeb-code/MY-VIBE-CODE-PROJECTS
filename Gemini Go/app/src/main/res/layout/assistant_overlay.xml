<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00000000">

    <!-- The Scrim (Semi-transparent background, fades in) -->
    <View
        android:id="@+id/scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#4D000000"
        android:alpha="0" />

    <!-- Prompt Bar Container -->
    <LinearLayout
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#00000000"
        android:translationY="300dp">

        <!-- Animated Gradient Border Wrapper -->
        <FrameLayout
            android:id="@+id/gradientBorder"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:padding="2dp"
            android:background="@drawable/assistant_gradient_border">

            <!-- Main Prompt Bar -->
            <LinearLayout
                android:id="@+id/promptBar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/rounded_top_corners_white_bg"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:elevation="4dp"
                tools:ignore="UnusedAttribute">

                <ImageView
                    android:id="@+id/sparkIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_launcher_foreground"
                    android:contentDescription="@string/content_desc_spark"
                    app:tint="#4285F4" />

                <TextView
                    android:id="@+id/greetingText"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/assistant_ask_hint"
                    android:textColor="#5F6368"
                    android:textSize="18sp"
                    android:layout_marginStart="12dp"
                    android:fontFamily="sans-serif-medium"/>

                <ImageView
                    android:id="@+id/micIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_btn_speak_now"
                    android:contentDescription="@string/content_desc_mic"
                    app:tint="#5F6368"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

            </LinearLayout>
        </FrameLayout>

    </LinearLayout>

</FrameLayout>
